{
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "useRootPaddingAwareAlignments": true,
        "layout": {
            "contentSize": "930px",
            "wideSize": "1400px"
        },
        "spacing": {
            "blockGap": true,
            "margin": true,
            "padding": true,
            "units": ["px", "em", "rem", "vh", "vw"]
        }
    },
    "styles": {
        "blocks": {
            "core/image": {
                "spacing": {
                    "margin": {
                        "left": "auto",
                        "right": "auto"
                    }
                }
            },
            "core/heading": {
                "typography": {
                    "lineHeight": "1.3"
                }
            },
            "core/list": {
                "spacing": {
                    "blockGap": "0.5em"
                }
            }
        },
        "elements": {
            "link": {
                "typography": {
                    "textDecoration": "none"
                }
            },
            "button": {
                "border": {
                    "radius": "0",
                    "width": "1px",
                    "style": "solid",
                    "color": "rgba(0, 0, 0, 0.3)"
                },
                "typography": {
                    "fontSize": "14px",
                    "lineHeight": "1",
                    "fontWeight": "600"
                },
                "spacing": {
                    "padding": {
                        "top": "9px",
                        "bottom": "9px",
                        "left": "15px",
                        "right": "15px"
                    }
                }
            }
        }
    }
}